{
  "name": "@pairup/frontend",
  "version": "0.0.0",
  "private": true,
  "description": "PairUp frontend — vanilla TypeScript modules built with esbuild. Output consumed by @pairup/web.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:dev": "node build.mjs --dev",
    "typecheck": "tsc --noEmit",
    "watch": "node build.mjs --watch"
  },
  "dependencies": {
    "@pairup/matching": "*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
